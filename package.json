{
  "name": "@prcompass/pr-triage-filter",
  "version": "0.1.0",
  "description": "A deterministic PR file-triage filter. Zero runtime dependencies. Written in TypeScript, runs on Node 22+.",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "keywords": [
    "pr",
    "pull-request",
    "code-review",
    "github",
    "triage",
    "typescript",
    "zero-deps"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/nkwib/prcompass.git",
    "directory": "packages/tier1-filter"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "bench": "vitest bench --run"
  },
  "dependencies": {},
  "devDependencies": {
    "@prcompass/prompts": "workspace:*",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^2.1.8",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false
}
